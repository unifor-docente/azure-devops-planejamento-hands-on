SELECT
  [System.Id],
  [System.WorkItemType],
  [System.Title],
  [System.State],
  [System.AssignedTo],
  [System.Tags]
FROM WorkItems
WHERE
  [System.TeamProject] = @project
  AND [System.WorkItemType] IN ('Epic', 'Requirement', 'Change Request', 'Task')
  AND [System.State] <> 'Closed'
ORDER BY
  [System.WorkItemType],
  [System.ChangedDate] DESC

