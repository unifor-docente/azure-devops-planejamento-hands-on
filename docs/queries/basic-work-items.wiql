SELECT
  [System.Id],
  [System.WorkItemType],
  [System.Title],
  [System.State],
  [System.AssignedTo],
  [System.Tags]
FROM WorkItems
WHERE
  [System.TeamProject] = @project
  AND [System.WorkItemType] IN ('Epic', 'Issue', 'Task')
  AND [System.State] <> 'Done'
ORDER BY
  [System.WorkItemType],
  [System.ChangedDate] DESC

